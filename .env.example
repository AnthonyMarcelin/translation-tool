# Copy to .env and fill in before running `docker compose up`.
# docker-compose.yml reads these for the backend container.

# REQUIRED in production — generate with: openssl rand -hex 32
JWT_SECRET=

# Public URL of the frontend (used for invite links in emails).
APP_URL=http://localhost:3000

# CORS allowed origins, comma-separated.
ALLOWED_ORIGINS=http://localhost:3000

# Optional SMTP — leave blank to log invite links to the console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Translation Tool <no-reply@translation.local>
